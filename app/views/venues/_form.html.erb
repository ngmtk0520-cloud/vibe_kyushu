<%= form_with(model: venue) do |form| %>
  <% if venue.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(venue.errors.count, "error") %> prohibited this venue from being saved:</h2>

      <ul>
        <% venue.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :address, style: "display: block" %>
    <%= form.text_field :address %>
  </div>

  <div>
    <%= form.label :instagram_url, style: "display: block" %>
    <%= form.text_field :instagram_url %>
  </div>

  <div class="field">
    <%= form.label :area, "エリア(県名)" %>
    <%= form.select :area, Venue::AREAS, {include_blank: "選択してください"} %>
  </div>

  <div class="field">
    <%= form.label :genre, "ジャンル" %>
    <%= form.select :genre, Event::GENRES, {include_blank: "選択してください"} %>
  </div>

  <div class="field">
    <%= form.label :pickup, "注目イベントにする" %>
    <%= form.checkbox :pickup %>
  </div>



  <div>
    <%= form.submit %>
  </div>
<% end %>
